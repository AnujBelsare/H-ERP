              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/assets/1", "host": ["{{baseUrl}}"], "path": ["api","assets","1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"location\": \"ICU Wing\",\n  \"status\": \"maintenance\"\n}"
            }
          }
        },
        {
          "name": "Delete Asset (admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/assets/1", "host": ["{{baseUrl}}"], "path": ["api","assets","1"] }
          }
        },
        {
          "name": "Create Asset — Validation Error (missing fields)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
