{
  "info": {
    "name": "HERP API — Full Collection",
    "_postman_id": "herp-api-collection-v3",
    "description": "Hospital Equipment & Resource Platform — all endpoints from xlsx spec",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000", "type": "string" },
    { "key": "adminToken",     "value": "", "type": "string" },
    { "key": "techToken",      "value": "", "type": "string" },
    { "key": "receptionToken", "value": "", "type": "string" },
    { "key": "doctorToken",    "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Signup — Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/signup", "host": ["{{baseUrl}}"], "path": ["api","auth","signup"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@herp.com\",\n  \"password\": \"Admin@1234\",\n  \"role\": \"admin\"\n}" }
          }
        },
        {
          "name": "Signup — Technician",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/signup", "host": ["{{baseUrl}}"], "path": ["api","auth","signup"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Tech User\",\n  \"email\": \"tech@herp.com\",\n  \"password\": \"Tech@1234\",\n  \"role\": \"technician\"\n}" }
          }
        },
        {
          "name": "Signup — Receptionist",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/signup", "host": ["{{baseUrl}}"], "path": ["api","auth","signup"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Reception User\",\n  \"email\": \"reception@herp.com\",\n  \"password\": \"Recep@1234\",\n  \"role\": \"receptionist\"\n}" }
          }
        },
        {
          "name": "Signup — Doctor",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/signup", "host": ["{{baseUrl}}"], "path": ["api","auth","signup"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Doctor User\",\n  \"email\": \"doctor@herp.com\",\n  \"password\": \"Doctor@1234\",\n  \"role\": \"doctor\"\n}" }
          }
        },
        {
          "name": "Login — Admin (saves token)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript",
            "exec": ["const j=pm.response.json(); if(j.data&&j.data.token) pm.collectionVariables.set('adminToken', j.data.token);"]
          }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@herp.com\",\n  \"password\": \"Admin@1234\"\n}" }
          }
        },
        {
          "name": "Login — Technician (saves token)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript",
            "exec": ["const j=pm.response.json(); if(j.data&&j.data.token) pm.collectionVariables.set('techToken', j.data.token);"]
          }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"tech@herp.com\",\n  \"password\": \"Tech@1234\"\n}" }
          }
        },
        {
          "name": "Login — Receptionist (saves token)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript",
            "exec": ["const j=pm.response.json(); if(j.data&&j.data.token) pm.collectionVariables.set('receptionToken', j.data.token);"]
          }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"reception@herp.com\",\n  \"password\": \"Recep@1234\"\n}" }
          }
        },
        {
          "name": "Login — Doctor (saves token)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript",
            "exec": ["const j=pm.response.json(); if(j.data&&j.data.token) pm.collectionVariables.set('doctorToken', j.data.token);"]
          }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"doctor@herp.com\",\n  \"password\": \"Doctor@1234\"\n}" }
          }
        }
      ]
    },
    {
      "name": "2. Assets",
      "item": [
        {
          "name": "Add Asset",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/assets", "host": ["{{baseUrl}}"], "path": ["api","assets"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"MRI Machine\",\n  \"category\": \"Imaging\",\n  \"serialNumber\": \"SN-MRI-001\",\n  \"qrCode\": \"QR-MRI-001\",\n  \"location\": \"Radiology Wing\",\n  \"status\": \"functional\"\n}" }
          }
        },
        {
          "name": "Get Assets",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/assets", "host": ["{{baseUrl}}"], "path": ["api","assets"] }
          }
        },
        {
          "name": "Scan QR Code",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{techToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/assets/qr/QR-MRI-001", "host": ["{{baseUrl}}"], "path": ["api","assets","qr","QR-MRI-001"] }
          }
        },
        {
          "name": "Generate QR — POST /api/qr",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/qr", "host": ["{{baseUrl}}"], "path": ["api","qr"] },
            "body": { "mode": "raw", "raw": "{\n  \"assetId\": 1\n}" }
          }
        },
        {
          "name": "Update Asset",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/assets/1", "host": ["{{baseUrl}}"], "path": ["api","assets","1"] },
            "body": { "mode": "raw", "raw": "{\n  \"location\": \"ICU Wing\",\n  \"status\": \"maintenance\"\n}" }
          }
        },
        {
          "name": "Delete Asset",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/assets/1", "host": ["{{baseUrl}}"], "path": ["api","assets","1"] }
          }
        }
      ]
    },
    {
      "name": "3. Breakdown",
      "item": [
        {
          "name": "Raise Breakdown — POST /api/breakdown",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{techToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/breakdown", "host": ["{{baseUrl}}"], "path": ["api","breakdown"] },
            "body": { "mode": "raw", "raw": "{\n  \"assetId\": 1,\n  \"issue\": \"Machine is making loud noise and not starting\",\n  \"photo\": null\n}" }
          }
        },
        {
          "name": "Get Breakdown (all) — GET /api/breakdown",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/breakdown", "host": ["{{baseUrl}}"], "path": ["api","breakdown"] }
          }
        },
        {
          "name": "Get Breakdown (filter by status)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/breakdown?status=open",
              "host": ["{{baseUrl}}"], "path": ["api","breakdown"],
              "query": [{ "key": "status", "value": "open" }]
            }
          }
        },
        {
          "name": "Approve Breakdown — POST /api/breakdown/approve",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/breakdown/approve", "host": ["{{baseUrl}}"], "path": ["api","breakdown","approve"] },
            "body": { "mode": "raw", "raw": "{\n  \"ticketId\": 1\n}" }
          }
        }
      ]
    },
    {
