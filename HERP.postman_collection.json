          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/patients/1", "host": ["{{baseUrl}}"], "path": ["api","patients","1"] }
