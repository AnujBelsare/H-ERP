{
  "info": {
    "name": "HERP API",
    "_postman_id": "herp-api-collection",
    "description": "Hospital Equipment & Resource Platform — full API collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "adminToken", "value": "", "type": "string" },
    { "key": "techToken", "value": "", "type": "string" },
    { "key": "receptionToken", "value": "", "type": "string" },
    { "key": "doctorToken", "value": "", "type": "string" }
