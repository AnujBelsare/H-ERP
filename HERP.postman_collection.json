            "url": { "raw": "{{baseUrl}}/api/auth/signup", "host": ["{{baseUrl}}"], "path": ["api","auth","signup"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@herp.com\",\n  \"password\": \"Admin@1234\",\n  \"role\": \"admin\"\n}"
            }
          }
