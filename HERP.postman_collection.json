    {
      "name": "Assets",
      "item": [
        {
          "name": "Create Asset (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/assets", "host": ["{{baseUrl}}"], "path": ["api","assets"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"MRI Machine\",\n  \"category\": \"Imaging\",\n  \"serialNumber\": \"SN-MRI-001\",\n  \"qrCode\": \"QR-MRI-001\",\n  \"location\": \"Radiology Wing\",\n  \"status\": \"functional\"\n}"
            }
          }
        },
        {
          "name": "List Assets (admin/technician)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/assets", "host": ["{{baseUrl}}"], "path": ["api","assets"] }
          }
        },
        {
          "name": "Scan QR Code",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{techToken}}" }],
